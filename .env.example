# ========================================
# НАСТРОЙКИ САЙТА opora-migration.ru
# ========================================
# Скопируйте этот файл как .env.local и заполните значения:
#   cp .env.example .env.local

# === НАСТРОЙКИ ПОЧТЫ ===
# Логин от почты mail.ru (от которой отправляются письма с форм сайта)
SMTP_USER=Migratsiya_opora@mail.ru
# Пароль приложения mail.ru (НЕ основной пароль от почты!)
# Как получить: mail.ru → Настройки → Безопасность → Пароли приложений
SMTP_PASSWORD=ваш_пароль_приложения
# Куда приходят заявки с сайта (обычно тот же email)
SMTP_TO=Migratsiya_opora@mail.ru

# === НАСТРОЙКИ АДМИНКИ ===
# Логин для входа в панель управления сайтом (opora-migration.ru/admin)
ADMIN_USERNAME=admin
# Пароль для входа в панель управления (придумайте сложный — минимум 8 символов!)
ADMIN_PASSWORD=ваш_сложный_пароль
# Секретный ключ для токенов авторизации (минимум 32 символа, случайная строка)
# Сгенерировать: openssl rand -base64 32
JWT_SECRET=ваш_случайный_секретный_ключ_минимум_32_символа

# === НАСТРОЙКИ СЕРВЕРА ===
# Адрес сайта (без / в конце)
NEXT_PUBLIC_SITE_URL=https://opora-migration.ru
# Порт на котором запускается сайт (по умолчанию 3000)
PORT=3000
